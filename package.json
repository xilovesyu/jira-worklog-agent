{
  "name": "jira-worklog-agent",
  "version": "1.0.0",
  "description": "Jira Worklog Auto-Recorder Agent",
  "type": "module",
  "main": "src/index.mjs",
  "bin": "dist/bundle.js",
  "scripts": {
    "start": "node src/index.mjs",
    "start:prod": "cross-env PRODUCTION_MODE=true node src/index.mjs",
    "dev": "node --watch src/index.mjs",
    "dev:ui": "npm run dev --prefix ui",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:ui\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "npm run build:ui && npm run build:embed-wasm && npm run build:bundle && npm run build:pkg && npm run build:copy-to-dist",
    "build:installer": "npm run build && installer\\build-installer.bat",
    "build:copy-dist-local": "node scripts/install.mjs",
    "build:ui": "npm run build --prefix ui",
    "build:embed-wasm": "node scripts/embed-wasm.mjs",
    "build:bundle": "esbuild src/index.mjs --bundle --platform=node --outfile=dist/bundle.js --format=cjs --target=node18 --external:node-notifier",
    "build:pkg": "pkg dist/bundle.js --targets node18-win-x64 --output dist/jira-worklog-agent.exe --compress GZip",
    "build:copy-to-dist": "node scripts/release.mjs"
  },
  "pkg": {
    "assets": [],
    "scripts": false,
    "outputPath": "dist"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "node-cron": "^3.0.3",
    "node-notifier": "^10.0.1",
    "openai": "^6.38.0",
    "sql.js": "^1.8.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^8.2.2",
    "esbuild": "^0.28.0",
    "pkg": "^5.8.1",
    "vitest": "^4.1.5"
  }
}
